API_HOST=0.0.0.0
API_PORT=3001
DATABASE_PROFILE=almohaseb

# Optional: preconfigure SQL Server from environment instead of config/connection.json
SQL_SERVER=
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
SQL_PORT=1433
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true
SQL_TDS_VERSION=7_3_A

# Windows native driver mode is recommended for SQL Server 2008/R2 and named instances.
# Use "tedious" only if you specifically want the pure JavaScript driver.
SQL_DRIVER=msnodesqlv8
SQL_ODBC_DRIVER=SQL Server

CONNECTION_CONFIG_PATH=./config/connection.json

# Optional Telegram AI assistant.
# TELEGRAM_ALLOWED_CHAT_IDS is a comma-separated list of Telegram chat IDs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# StockCount Pro server-to-server API.
# Never expose STOCKCOUNT_API_KEY in browser code, Vite variables, Lovable frontend,
# localStorage, or any public client. Store it only in a trusted backend/edge function.
STOCKCOUNT_API_KEY=
STOCKCOUNT_ALLOWED_ORIGINS=
STOCKCOUNT_RATE_WINDOW_MS=60000
STOCKCOUNT_RATE_MAX=120
